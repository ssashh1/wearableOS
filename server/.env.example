# Whoop datastore + ingest. Copy to .env and fill in. Do NOT commit .env.
# Bearer token the uploader/phone must send (Authorization: Bearer <this>).
WHOOP_API_KEY=change_me
# TimescaleDB credentials (whoop-db container).
WHOOP_DB_NAME=whoop
WHOOP_DB_USER=whoop
WHOOP_DB_PASSWORD=change_me
# Host port the ingest API is published on (container listens on 8000).
WHOOP_INGEST_PORT=8770
